# Keep the build context lean and — critically — keep the host's
# node_modules out of the image. The Dockerfile runs `pnpm install` to build
# a linux/alpine node_modules; if the host copy (macOS/arm) were COPYed in
# afterwards it would clobber that with the wrong-platform binaries.
node_modules
dist
.vite
.pnpm-store

# Local tooling / VCS noise
.git
.gitignore
*.log
.DS_Store
