# Local Makefile overrides — copy to `local.mk` and edit.
#
#   cp local.mk.example local.mk
#
# `local.mk` is gitignored. The Makefile `-include`s it, so any variable set
# here overrides the in-Makefile defaults without touching tracked files.
# The command line still wins over this file (`make release DEPLOY_HOST=...`).

# SSH target for `make release` / `make release-current` image deployment.
DEPLOY_HOST = user@homelab

# Directory on DEPLOY_HOST holding the prod compose files + .env. After loading
# the new image, the release recreates the stack with `docker compose up -d`
# there. Defaults to /home/user; override if your host differs.
DEPLOY_PATH = /home/user
